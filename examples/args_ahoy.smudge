ArgsAhoy
{
  * ArgsAhoy (@oneArg @takesVoid)
    [
        multiple-args -(@twoArgsWithDefault @f set-up-conflict, @threeArgsWithDefault set-up-conflict trigger-conflict @e)-,
        set-up-conflict -(@setUpConflict @conflict)-,
        trigger-conflict -(@triggerConflict @conflict)-,
    ]
}
